# kbcraft environment — copy to .env and adjust values
QWEN3_HOST=http://localhost:11434
QWEN3_MODEL=qwen3-embedding:0.6b
QWEN3_MAX_TOKENS=32768
OLLAMA_HOST=http://localhost:11434
SAVE_VECTORDB=false

# OpenAI embeddings (test_cli_index_openai.py)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_MAX_TOKENS=8191

# AWS / S3 connection — defaults match the MinIO service in
# docker-compose.dev.yml. Read by scripts/e2e_faiss_s3.sh and by
# ConfigFactory.load_storage(). Override with real values to point at AWS.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
STORAGE_S3_ENDPOINT_URL=http://localhost:9000   # leave blank for real AWS
STORAGE_BACKEND=s3
KBCRAFT_S3_BUCKET=kbcraft-e2e
