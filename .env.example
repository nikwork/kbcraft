# kbcraft environment — copy to .env and adjust values
QWEN3_HOST=http://localhost:11434
QWEN3_MODEL=qwen3-embedding:0.6b
QWEN3_MAX_TOKENS=32768
OLLAMA_HOST=http://localhost:11434
SAVE_VECTORDB=false

# OpenAI embeddings (test_cli_index_openai.py)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_MAX_TOKENS=8191

# S3 connection — the single source of S3 credentials + connection info, all
# under a unified S3_ prefix. Read by ConfigFactory.load_storage() (env wins
# over configs/storage.yaml) and thus by every S3 consumer: scripts/e2e_faiss_s3.sh,
# the S3 export steps in scripts/test_cli_index_openai.{sh,py}, and
# scripts/s3_export.py (boto3). Defaults below match the MinIO service in
# docker-compose.dev.yml; override to point at AWS or another S3-compatible cloud.
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://localhost:9000   # leave blank for real AWS
S3_BUCKET=kbcraft-e2e
STORAGE_BACKEND=s3
# Optional: for temporary STS creds or a named ~/.aws/credentials profile.
# S3_SESSION_TOKEN=
# S3_PROFILE=
